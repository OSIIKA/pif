<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/result.css">
</head>
<body class="">
  <% if @finaresult == "勝利" %>
    <p>勝利！</p>
  <% elsif @finaresult == "敗北" %>
    <p>敗北</p>
  <% end %>
  <div class="unitss">
    <div class="units">
      <p>味方ユニット</p>
      <% @my_units.each do |freet_list| %>
        <% freet_list.each do |freet| %>
          <div style="background: #222; border: 1px solid #444; padding: 15px; margin-bottom: 10px; border-radius: 4px;">
            <strong><%= freet['myfreet']['name'] %></strong> (Lv.<%= freet['level'] %>) <br>
            HP: <%= freet['myfreet']['hp'] %> / <%= freet['myfreet']['max_hp'] %> | 
            攻撃力: <%= freet['myfreet']['atk'] %> <br>
            <span style="color: #888; font-size: 0.9em;"><%= freet['myfreet']['info'] %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
  <form action="/home" method="get">
    <input type="submit" value="戻る">
  </form>
</body>
</html>