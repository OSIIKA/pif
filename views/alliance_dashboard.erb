<div style="max-width: 600px; margin: 40px auto; padding: 20px; background-color: #141414; border: 1px solid #333; border-radius: 8px; color: #fff;">
  
  <% if session[:error] %>
    <div style="background-color: #ff4d4f; color: #fff; padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 14px;">
      ⚠️ <%= session[:error] %><% session[:error] = nil %>
    </div>
  <% end %>

  <h2>🛡️ 同盟マイページ</h2>
  
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
    <h1 style="color: #bae7ff; margin: 0;"><%= @alliance.name %></h1>
    <button id="menu-open-btn" style="background: #222; border: 1px solid #444; color: #fff; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold; transition: background 0.2s;">
      ⚙️ メニュー
    </button>
  </div>

  <p>盟主: <strong><%= @alliance.leader.name %></strong> | レベル: <%= @alliance.level %> | EXP: <%= @alliance.exp %></p>

  <hr style="border-color: #2b416d; margin: 20px 0;">

  <h3>👥 所属メンバー一覧</h3>
  <ul>
    <% @alliance.users.each do |member| %>
      <li><%= member.name %> (Lv: <%= member.level %>)</li>
    <% end %>
  </ul>

  <p style="margin-top: 30px;">
    <a href="/home" style="color: #1890ff; text-decoration: none;">➔ ホームに戻る</a>
  </p>

  <div id="chat-preview-bar" style="max-width: 600px; margin: 20px auto; padding: 12px 15px; background-color: #141414; border: 1px solid #2b416d; border-radius: 6px; color: #fff; cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; gap: 10px; align-items: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; flex: 1; font-size: 14px;">
      <span style="color: #52c41a; font-weight: bold; flex-shrink: 0;">🛡️ 同盟チャット:</span>
      <% if @alliance_chats.empty? %>
        <span style="color: #555;">作戦会議を始めましょう！</span>
      <% else %>
        <% last_chat = @alliance_chats.last %>
        <span style="color: #bae7ff; font-weight: bold; flex-shrink: 0;"><%= last_chat.user.name %>:</span>
        <span style="color: #ddd; overflow: hidden; text-overflow: ellipsis;"><%= last_chat.body %></span>
      <% end %>
    </div>
    <span style="color: #666; font-size: 12px; margin-left: 10px; flex-shrink: 0;">開く ➔</span>
  </div>

  <div id="chat-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); z-index: 2000; justify-content: center; align-items: center;">
    <div style="max-width: 600px; width: 90%; padding: 20px; background-color: #141414; border: 1px solid #2b416d; border-radius: 8px; color: #fff; position: relative;">
      <button id="chat-close-btn" style="position: absolute; top: 12px; right: 15px; background: none; border: none; color: #aaa; font-size: 22px; cursor: pointer;">✕</button>
      <h3 style="margin-top: 0; margin-bottom: 15px; color: #52c41a;">🛡️ 同盟チャット（作戦会議）</h3>
      <div id="chat-history-scroll" style="height: 300px; overflow-y: auto; background-color: #000; padding: 12px; border-radius: 4px; border: 1px solid #222; margin-bottom: 15px;">
        <% if @alliance_chats.empty? %>
          <p style="color: #555; text-align: center; margin-top: 130px;">まだ発言はありません。最初のメッセージをどうぞ！</p>
        <% else %>
          <% @alliance_chats.each do |chat| %>
            <div style="margin-bottom: 10px; font-size: 14px; line-height: 1.4;">
              <span style="color: #bae7ff; font-weight: bold;"><%= chat.user.name %></span>
              <span style="color: #666; font-size: 11px; margin-left: 5px;"><%= chat.created_at.strftime('%m/%d %H:%M') %></span>
              <div style="color: #ddd; margin-left: 10px; word-wrap: break-word;"><%= chat.body %></div>
            </div>
          <% end %>
        <% end %>
      </div>
      <form action="/alliance/chat" method="post" style="display: flex; gap: 10px; margin: 0;">
        <input type="text" name="chat_body" placeholder="同盟メンバーにメッセージを送信" maxlength="100" required style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #444; background: #222; color: #fff;">
        <button type="submit" style="padding: 10px 20px; background-color: #52c41a; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">送信</button>
      </form>
    </div>
  </div>

  <div id="menu-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); z-index: 1900; justify-content: center; align-items: center;">
    <div style="max-width: 600px; width: 90%; padding: 20px; background-color: #1a1a1a; border: 1px solid #444; border-radius: 8px; color: #fff; position: relative;">
      
      <button id="menu-close-btn" style="position: absolute; top: 12px; right: 15px; background: none; border: none; color: #aaa; font-size: 22px; cursor: pointer;">✕</button>
      <h3 style="margin-top: 0; margin-bottom: 20px; color: #bae7ff;">🛠️ 同盟管理メニュー</h3>

      <div style="display: flex; gap: 5px; border-bottom: 1px solid #444; padding-bottom: 10px; margin-bottom: 20px;">
        <button class="tab-btn active" data-tab="tab-leader" style="flex: 1; padding: 8px; background: #333; border: none; color: #fff; cursor: pointer; font-weight: bold; font-size: 12px; border-radius: 4px;">盟主専用</button>
        <button class="tab-btn" data-tab="tab-main" style="flex: 1; padding: 8px; background: #222; border: none; color: #aaa; cursor: pointer; font-weight: bold; font-size: 12px; border-radius: 4px;">主要な操作</button>
        <button class="tab-btn" data-tab="tab-manage" style="flex: 1; padding: 8px; background: #222; border: none; color: #aaa; cursor: pointer; font-weight: bold; font-size: 12px; border-radius: 4px;">管理・脱退など</button>
      </div>

      <div id="tab-leader" class="tab-content" style="display: block; min-height: 150px;">
        <p style="color: #aaa;">🔒 盟主専用コマンド（開発中・保留）</p>
        <p style="font-size: 13px; color: #666;">※ここには盟主だけに向けた特別な設定画面を表示する予定です。</p>
      </div>

      <div id="tab-main" class="tab-content" style="display: none; min-height: 150px;">
        <p style="color: #aaa;">⚡ 主要な操作（拡張予定地）</p>
        <p style="font-size: 13px; color: #666;">※同盟のクエスト出撃や、バフの発動などの操作を予定しています。</p>
      </div>

      <div id="tab-manage" class="tab-content" style="display: none; min-height: 150px; flex-direction: column; justify-content: space-between;">
        <div>
          <p style="color: #aaa; margin-top: 0;">👥 招待・メンバーランク管理（予定）</p>
          <p style="font-size: 13px; color: #666;">※メンバーの役職変更や招待機能の予定地です。</p>
        </div>
        
        <div style="border-top: 1px solid #333; padding-top: 15px; margin-top: 20px; text-align: right;">
          <form action="/alliance/leave" method="post" onsubmit="return confirm('本当にこの同盟を脱退しますか？');" style="margin: 0;">
            <button type="submit" style="padding: 10px 20px; background-color: #ff4d4f; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; transition: background 0.2s;">
              🏃 同盟から脱退する
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>

  <script src="/js/home_chat.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const menuOpenBtn = document.getElementById("menu-open-btn");
      const menuCloseBtn = document.getElementById("menu-close-btn");
      const menuOverlay = document.getElementById("menu-overlay");
      const tabButtons = document.querySelectorAll(".tab-btn");
      const tabContents = document.querySelectorAll(".tab-content");

      // メニューを開く
      menuOpenBtn.addEventListener("click", function() {
        menuOverlay.style.display = "flex";
      });

      // メニューを閉じる
      menuCloseBtn.addEventListener("click", function() {
        menuOverlay.style.display = "none";
      });

      // タブ切り替えの魔法
      tabButtons.forEach(btn => {
        btn.addEventListener("click", function() {
          // すべてのボタンの選択状態（色）をリセット
          tabButtons.forEach(b => {
            b.style.background = "#222";
            b.style.color = "#aaa";
          });
          // クリックされたボタンをアクティブ化
          this.style.background = "#333";
          this.style.color = "#fff";

          // すべてのコンテンツを一旦非表示にする
          tabContents.forEach(content => content.style.display = "none");
          
          // ボタンの data-tab に紐づくコンテンツだけをパッと表示
          const targetId = this.getAttribute("data-tab");
          document.getElementById(targetId).style.display = "block";
        });
      });
    });
  </script>
</div>