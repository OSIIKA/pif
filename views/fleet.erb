<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>艦隊管理 - 紫鉄艦隊</title>
</head>
<body style="background: #141414; color: #fff; padding: 20px; font-family: sans-serif;">
    <% screen = @screen %>

    <%# 初回アクセス時は画面選択メニューを表示する %>
    <% if screen == 'menu' %>
      <h1>⚓ 艦隊管理メニュー</h1>
      <div style="background: #111; border: 1px solid #333; padding: 30px; border-radius: 10px; text-align: center; max-width: 520px; margin: 40px auto;">
        <p style="color: #ccc; margin-bottom: 25px;">操作したい画面を選択してください。</p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a href="/fleet?screen=formation&fleet_num=1" style="display: inline-block; padding: 14px 22px; background: #ffbc00; color: #000; border-radius: 6px; text-decoration: none; font-weight: bold;">
            編成
          </a>
          <a href="/fleet?screen=owned" style="display: inline-block; padding: 14px 22px; background: #096dd9; color: #fff; border-radius: 6px; text-decoration: none; font-weight: bold;">
            所持艦一覧
          </a>
          <a href="/home" style="display: inline-block; padding: 14px 22px; background: #444; color: #fff; border-radius: 6px; text-decoration: none; font-weight: bold;">
            ホームに戻る
          </a>
        </div>
      </div>

    <% elsif screen == 'formation' %>
      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 20px;">
        <h1>⚓ 艦隊編成</h1>
        <a href="/fleet" style="display: inline-block; padding: 10px 16px; background: #222; color: #fff; border-radius: 6px; text-decoration: none; border: 1px solid #555;">メニューに戻る</a>
      </div>
      <% 
        # すでにどこかの艦隊に登録されている艦のIDをすべて集める
        assigned_ids = UserBattleunit.all.map { |f| [f.flagship_id, f.sub_ship_1_id, f.sub_ship_2_id, f.sub_ship_3_id, f.sub_ship_4_id, f.sub_ship_5_id, f.sub_ship_6_id] }.flatten.compact.uniq
      %>
      <div style="background: #111; border: 1px solid #333; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
  
      <div style="display: flex; gap: 10px; justify-content: center; margin-bottom: 20px; flex-wrap: wrap;">
        <% (1..6).each do |num| %>
          <a href="/fleet?screen=formation&fleet_num=<%= num %>" 
             style="padding: 8px 16px; border-radius: 4px; text-decoration: none; font-weight: bold; 
                    background: <%= @current_fleet_num == num ? '#ffbc00' : '#222' %>; 
                    color: <%= @current_fleet_num == num ? '#000' : '#fff' %>; 
                    border: 1px solid #555;">
            第<%= %w(一 二 三 四 五 六)[num-1] %>艦隊
          </a>
        <% end %>
      </div>

      <h2 style="text-align: center; color: #ffbc00; font-size: 1.2em; margin-bottom: 20px;">
        ⚓ 第<%= %w(一 二 三 四 五 六)[@current_fleet_num-1] %>艦隊 編成状況 （総員、戦闘配置！）
      </h2>

      <div style="display: flex; flex-direction: column; align-items: center; gap: 20px;">
  
        <div style="border: 2px solid #ffbc00; background: rgba(255, 188, 0, 0.05); padding: 15px; border-radius: 8px; width: 220px; text-align: center;">
          <span style="color: #ffbc00; font-size: 0.8em; font-weight: bold; display: block; margin-bottom: 5px;">★ 旗艦 ★</span>
          <% if @flagship %>
            <% master = @flagship.dictionary %>
            <strong style="color: #fff;"><%= master.name %></strong>
            <span style="font-size: 0.8em; color: #aaa;">(Lv.<%= @flagship.level %>)</span>
            <form action="/fleet/set_ship" method="post" style="margin-top: 8px;">
              <input type="hidden" name="fleet_num" value="<%= @current_fleet_num %>">
              <input type="hidden" name="slot_type" value="flagship">
              <input type="hidden" name="screen" value="formation">
              <input type="hidden" name="user_myfreet_id" value="">
              <button type="submit" style="font-size: 0.75em; background: #c0392b; color: #fff; border: none; padding: 2px 8px; border-radius: 3px; cursor: pointer;">外す</button>
            </form>
          <% else %>
            <button type="button" onclick="openSelectionModal('flagship')" 
                    style="margin-top: 10px; font-size: 0.85em; background: #ffbc00; color: #000; border: none; padding: 5px 15px; font-weight: bold; border-radius: 4px; cursor: pointer;">
              ➕ 旗艦を選択
            </button>
          <% end %>
        </div>

        <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
          <% (1..6).each do |i| %>
            <% sub_ship = @sub_ships[i-1] %>
            <div style="border: 1px dashed #555; background: rgba(255,255,255,0.02); padding: 10px; border-radius: 6px; width: 130px; text-align: center; font-size: 0.9em;">
              <span style="color: #aaa; font-size: 0.8em; display: block; margin-bottom: 5px;">随伴艦 <%= i %></span>
              <% if sub_ship %>
                <strong style="color: #fff;"><%= sub_ship.allfreet.name %></strong> <span style="font-size: 0.8em; color: #aaa;">(Lv.<%= sub_ship.level %>)</span>
                <form action="/fleet/set_ship" method="post" style="margin-top: 5px;">
                  <input type="hidden" name="fleet_num" value="<%= @current_fleet_num %>">
                  <input type="hidden" name="slot_type" value="sub_<%= i %>">
                  <input type="hidden" name="screen" value="formation">
                  <input type="hidden" name="user_myfreet_id" value="">
                  <button type="submit" style="font-size: 0.7em; background: #555; color: #fff; border: none; padding: 1px 5px; border-radius: 3px; cursor: pointer;">外す</button>
                </form>
              <% else %>
                <button type="button" onclick="openSelectionModal('sub_<%= i %>')" 
                        style="margin-top: 8px; font-size: 0.8em; background: #007bff; color: #fff; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer;">
                  ➕ 選択
                </button>
              <% end %>
            </div>
          <% end %>
        </div>

      </div>
    </div>

    <hr style="border: 0; border-top: 1px solid #333; margin: 40px 0;">
  <% elsif screen == 'owned' %>
      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 20px;">
        <h1>⚓ 所持艦一覧</h1>
        <a href="/fleet" style="display: inline-block; padding: 10px 16px; background: #222; color: #fff; border-radius: 6px; text-decoration: none; border: 1px solid #555;">メニューに戻る</a>
      </div>
      <p>司令官: <strong><%= @user.name %></strong> が現在保有している戦力一覧です。</p>

      <hr style="border: 0; border-top: 1px solid #333; margin: 20px 0;">
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;">
      
      <% if @my_ships.any? %>
        <% @my_ships.each do |my_freet| %>
          <% master = my_freet.dictionary %>
          <div style="background: #222; border: 1px solid #444; border-top: 4px solid #096dd9; padding: 15px; border-radius: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.3);">
            <div style="display: flex; justify-content: space-between; font-size: 0.85em; margin-bottom: 8px;">
              <span style="color: #deff9a; font-weight: bold;">[<%= master.rarity_text %>]</span>
              <span style="color: #096dd9; font-weight: bold;">Lv. <%= my_freet.level %></span>
            </div>
            <div style="font-size: 1.15em; font-weight: bold; margin-bottom: 12px; color: #fff;">
              <%= master.name %>
            </div>
            <div style="font-size: 0.9em; color: #ccc; line-height: 1.5; background: #1a1a1a; padding: 8px; border-radius: 4px;">
              <div>❤️ HP: <%= master.hp %></div>
              <div>⚔️ 攻撃: <%= master.atk %></div>
              <div style="font-size: 0.8em; color: #888; margin-top: 5px; border-top: 1px solid #333; padding-top: 5px;">
                <%= master.info %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <p style="color: #666;">まだ艦船を所持していません。ガチャで作戦を展開しましょう！</p>
      <% end %>

    </div>

    <br><br>
    <hr style="border: 0; border-top: 1px solid #333; margin: 20px 0;">
    <a href="/home" style="color: #1890ff; text-decoration: none;">➔ ホームに戻る</a>
  <% end %>

  <% if screen == 'formation' %>
    <div id="fleetModalOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; justify-content: center; align-items: center;">
      <div style="background: #1a1a2e; border: 2px solid #ffbc00; border-radius: 10px; width: 90%; max-width: 500px; max-height: 80vh; display: flex; flex-direction: column; padding: 20px; box-shadow: 0 0 20px rgba(255,188,0,0.3);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
          <h3 style="color: #ffbc00; margin: 0; font-size: 1.2em;">🚢 配備艦船の選択</h3>
          <button type="button" onclick="closeSelectionModal()" style="background: none; border: none; color: #aaa; font-size: 1.5em; cursor: pointer;">&times;</button>
        </div>

        <input type="text" id="modalSearchInput" oninput="filterModalShips()" placeholder="🔍 艦船名で絞り込み..." 
               style="width: 100%; padding: 10px; background: #111; color: #fff; border: 1px solid #555; border-radius: 5px; margin-bottom: 15px; box-sizing: border-box;">

        <div id="modalShipList" style="overflow-y: auto; flex-grow: 1; display: flex; flex-direction: column; gap: 8px; padding-right: 5px;">
          <form id="modalFleetForm" action="/fleet/set_ship" method="post">
            <input type="hidden" name="fleet_num" value="<%= @current_fleet_num %>">
            <input type="hidden" name="screen" value="formation">
            <input type="hidden" id="modalSlotType" name="slot_type" value="">
            <input type="hidden" id="modalUserMyfreetId" name="user_myfreet_id" value="">

            <% @my_ships.each do |ms| %>
              <% next if assigned_ids.include?(ms.id) %>
              <div class="modal-ship-card" data-name="<%= master = ms.dictionary %>" onclick="submitModalSelection(<%= ms.id %>)"
                   style="background: #222; border: 1px solid #444; padding: 12px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; transition: 0.2s;">
                <div>
                  <strong style="color: #fff; font-size: 1em;"><%= master.name %></strong>
                  <span style="color: #ffbc00; font-size: 0.85em; margin-left: 10px;">Lv.<%= ms.level %></span>
                </div>
                <span style="font-size: 0.8em; color: #007bff; background: rgba(0,123,255,0.1); padding: 3px 8px; border-radius: 3px;">配備</span>
              </div>
            <% end %>
          </form>
        </div>
      </div>
    </div>
    <script src="/js/freet.js"></script>
    <style>
      /* カードにマウスを乗せたときのカッコいい光るエフェクト */
      .modal-ship-card:hover {
        background: #2d2d44 !important;
        border-color: #ffbc00 !important;
        box-shadow: 0 0 8px rgba(255,188,0,0.2);
      }
    </style>
  <% end %>
</body>
</html>