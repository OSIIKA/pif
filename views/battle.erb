<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css">
  
</head>
<body class="question-view">
  <header>
    
  </header>
  <main>
    
    <div class="unit-row">
      <% @my_units.each do |freet| %>
        <div class="unit-card">

          <!-- 艦画像（仮） -->
          <img src="/img/ship_placeholder.png" class="unit-img">

          <!-- 艦名 -->
          <div class="unit-name"><%= freet['myfreet']['name'] %></div>

          <!-- HPバー -->
          <div class="hp-bar">
            <div class="hp-bar-fill"
              data-id="<%= freet['myfreet']['id'] %>"
              data-hp="<%= freet['myfreet']['hp'] %>"
              data-max-hp="<%= freet['myfreet']['max_hp'] %>">
            </div>
          </div>

          <!-- iボタン（詳細オーバーレイ用） -->
          <button class="unit-info-button" data-unit="<%= freet.to_json %>">i</button>

        </div>
      <% end %>
    </div>
    <div class="unit-row">
      <% @enemy_units.each do |freet| %>
        <div class="unit-card">

          <img src="/img/ship_placeholder.png" class="unit-img">

          <div class="unit-name"><%= freet['name'] %></div>

          <div class="hp-bar">
            <div class="hp-bar-fill"
              data-id="<%= freet['id'] %>"
              data-hp="<%= freet['hp'] %>"
              data-max-hp="<%= freet['max_hp'] %>">
            </div>
          </div>

          <button class="unit-info-button" data-unit="<%= freet.to_json %>">i</button>

        </div>
      <% end %>
    </div>

    
    <form action="/battle/attack" method="post">
      <select name="my_unit_id" id="">
        <% @my_units.each do |my| %>
          <!--name→value-->
          <option value=<%= my['myfreet']['id'] %> ><%= my['myfreet']['name'] %></option>
        <% end %>
      </select>
      <select name="enemy_unit_id" id="">
        <% @enemy_units.each do |enemy| %>
          <!--name→value-->
          <option value=<%= enemy['id'] %> ><%= enemy['name'] %></option>
        <% end %>
      </select>
      <input type="submit" value="攻撃">
    </form>
    <!--ここにフォームを作っていく-->
    <!--攻撃するユニットと、攻撃を受けるユニットをそれぞれ選択する(Select)フォーム-->
    <!--フォームは /battle/attack に POST リクエストを送信-->
    <!--攻撃ユニットと被攻撃ユニットの ID が、それぞれ my_unit_id と enemy_unit_id というパラメータとして送信される-->
    <!--フォームを送信することで攻撃が実装されるイメージ-->
    <!-- ▼ 詳細オーバーレイ -->
    <div id="unit-detail-overlay" class="overlay">
      <div class="overlay-content">
        <button id="overlay-close" class="overlay-close">×</button>
        <div id="unit-detail-body"></div>
      </div>
    </div>
  </main>
  <script src="/js/battle.js"></script>
  <script src="/js/battle_detail.js"></script>
</body>
</html>