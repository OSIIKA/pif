<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css"?v=4>
  <link rel="stylesheet" href="/css/battle.css">
  <script src="/js/battle.js" defer></script>
</head>
<body class="question-view">
  <header>
    <div style="color: #ffbc00; font-weight: bold; font-size: 1.2em; font-family: monospace;">
      🛸 紫鉄艦隊 - BATTLE CONTROL
    </div>
    <!-- 画面最上部の操作ボタン -->
    <div style="display: flex; gap: 10px;">
      <button style="background: #222; color: #888; border: 1px solid #444; padding: 5px 15px; cursor: not-allowed;" disabled>
        🤖 オート（未実装）
      </button>
      
      <button style="background: #222; color: #888; border: 1px solid #444; padding: 5px 15px; cursor: not-allowed;" disabled>
        ⏩ 速度: x1（未実装）
      </button>

      <a href="/home" style="background: #5c0000; color: #fff; border: 1px solid #a00; padding: 5px 15px; text-decoration: none; font-size: 0.9em; font-weight: bold; border-radius: 3px;">
        🏳️ 撤退
      </a>
    </div>
  </header>
  <main>
    <div style="background: #111; color: #fff; padding: 30px; text-align: center; border: 1px solid #333; border-radius: 10px;">
      <h1 style="color: #ffbc00; font-size: 1.8em; margin-bottom: 10px;">⚔️ 作戦海域・戦闘フェーズ ⚔️</h1>
      <p style="color: #aaa; font-size: 1.1em; margin-bottom: 30px;">
        【 ステージ <%= @stage %> 】に突入しました。総員、対空・対潜戦闘配置！
      </p>

      <% if request.path_info == '/battle/set' %>
        <div id="phase-anim-container" style="position: fixed; top: 40%; left: -100%; transform: translate(-50%, -50%); z-index: 10000; pointer-events: none; transition: all 0.5s ease-out; white-space: nowrap;">
          <h2 style="color: #ffbc00; font-size: 2.5em; font-weight: bold; font-family: monospace; text-shadow: 0 0 20px rgba(255,188,0,0.6); background: rgba(5,5,15,0.8); padding: 15px 40px; border-top: 2px solid #ffbc00; border-bottom: 2px solid #ffbc00;">
            ⚡ 第一次海域・編成フェーズ進行中 ⚡
          </h2>
        </div>
        <% if @battle_error %>
          <div style="background: #3d0a0a; color: #ffdddd; border: 1px solid #ff4a4a; padding: 14px; margin-bottom: 18px; border-radius: 8px;">
            ⚠️ <%= @battle_error %>
          </div>
        <% end %>
        <div style="background: #222; border: 1px solid #444; padding: 20px; text-align: left; max-width: 500px; margin: 0 auto; border-radius: 6px;">
          <h3 style="color: #ffbc00; margin-top: 0; border-bottom: 1px solid #444; padding-bottom: 5px;">
            📊 出撃艦隊データ確認
          </h3>
          <ul style="list-style: none; padding-left: 0; line-height: 1.8;">
            <% @fleets.each do |f| %>
              <li>
                <strong>第<%= %w(一 二 三 四 五 六)[f.fleet_number-1] %>艦隊:</strong> 
                旗艦 ID[<%= f.flagship_id || "未配備" %>] / 随伴艦 6隻
              </li>
            <% end %>
          </ul>
        </div>

        <h3 style="color: #ffbc00; margin-top: 40px;">🌌 味方陣地・ヘックスグリッド展開</h3>
        <p style="color: #aaa; font-size: 0.9em; margin-bottom: 20px;">艦隊カードをマスまでドラッグ＆ドロップして配置し、配置後もドラッグで自由に位置調整が可能です。</p>

        <div id="fleetPaletteContainer" style="display: flex; gap: 15px; justify-content: center; margin-bottom: 20px;">
          <% @fleets.each do |f| %>
            <% 
              available = !f.flagship_id.nil?
              fleet_name = "第#{%w(一 二 三 四 五 六)[f.fleet_number-1]}艦隊"
            %>
            <div class="draggable-fleet-card <%= 'available' if available %>" 
                draggable="<%= available %>"
                data-fleet-num="<%= f.fleet_number %>"
                data-fleet-name="🚢：<%= fleet_name %>"
                ondragstart="handlePaletteDragStart(event)"
                style="background: #222; border: 1px solid #444; padding: 10px; border-radius: 4px; width: 140px; text-align: center; color: #fff; cursor: <%= available ? 'grab' : 'not-allowed' %>; user-select: none; transition: 0.2s; <%= 'opacity: 0.4;' unless available %>">
              <div style="font-weight: bold;"><%= fleet_name %></div>
              <div class="status-text" style="font-size: 0.8em; color: <%= available ? '#00ffbc' : '#ff4a4a' %>;">
                <%= available ? '配置可能' : '旗艦未配備' %>
              </div>
              <% if available %>
                <% flagship_obj = UserMyfreet.find_by(id: f.flagship_id) %>
                <% if flagship_obj && flagship_obj.allfreet %>
                  <div style="font-size: 0.8em; color: #aaa; margin-top: 5px;">
                    HP: <span style="color: #2ecc71;"><%= flagship_obj.allfreet.hp %></span> / <%= flagship_obj.allfreet.hp %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% elsif request.path_info == '/battle/prepare' %>
        <div id="phase-anim-container" style="position: fixed; top: 40%; left: -100%; transform: translate(-50%, -50%); z-index: 10000; pointer-events: none; transition: all 0.5s ease-out; white-space: nowrap;">
          <h2 style="color: #ff4a4a; font-size: 2.5em; font-weight: bold; font-family: monospace; text-shadow: 0 0 20px rgba(255,74,74,0.6); background: rgba(15,5,5,0.8); padding: 15px 40px; border-top: 2px solid #ff4a4a; border-bottom: 2px solid #ff4a4a;">
            ⚡ 第一次海域・哨戒戦技フェーズ進行中 ⚡
          </h2>
        </div>
      <% elsif request.path_info == '/battle/start' %>
        <div id="phase-anim-container" style="position: fixed; top: 40%; left: -100%; transform: translate(-50%, -50%); z-index: 10000; pointer-events: none; transition: all 0.5s ease-out; white-space: nowrap;">
          <h2 style="color: #ff4a4a; font-size: 2.5em; font-weight: bold; font-family: monospace; text-shadow: 0 0 20px rgba(255,74,74,0.6); background: rgba(15,5,5,0.8); padding: 15px 40px; border-top: 2px solid #ff4a4a; border-bottom: 2px solid #ff4a4a;">
            ⚡ 第一次海域・交戦フェーズ進行中 ⚡
          </h2>
        </div>
      <% else %>
        
      <% end %>

      <div class="battle-map-wrapper" style="background: #0d0d1a; border: 2px solid #007bff; border-radius: 8px; padding: 20px; display: inline-block; box-shadow: 0 0 15px rgba(0,123,255,0.2);">
        <%
          hex_width = 80
          hex_height = 70
          x_spacing = hex_width * 0.75
          y_spacing = hex_height

          map_rows = 5
          map_cols = 6

          svg_width = (map_cols * x_spacing) + (hex_width * 0.25) + 20
          svg_height = (map_rows * y_spacing) + (hex_height * 0.5) + 20
        %>

        <svg width="<%= svg_width %>" height="<%= svg_height %>" style="background: rgba(0,0,0,0.5);">
          <g transform="translate(10, 10)">
            <% (0...map_cols).each do |col| %>
              <% (0...map_rows).each do |row| %>
                <%
                  # Flat-Top Offset の幾何学座標計算
                  x = col * x_spacing
                  y = row * y_spacing
                  y += (hex_height / 2) if col % 2 == 1

                  p1 = "#{x}, #{y + hex_height / 2}"
                  p2 = "#{x + hex_width * 0.25}, #{y}"
                  p3 = "#{x + hex_width * 0.75}, #{y}"
                  p4 = "#{x + hex_width}, #{y + hex_height / 2}"
                  p5 = "#{x + hex_width * 0.75}, #{y + hex_height}"
                  p6 = "#{x + hex_width * 0.25}, #{y + hex_height}"
                  
                  points = "#{p1} #{p2} #{p3} #{p4} #{p5} #{p6}"
                  
                  # JSでの配置用にマスの中心座標を計算しておく
                  center_x = x + hex_width / 2
                  center_y = y + hex_height / 2
                %>
                
                <g class="hex-cell" 
                   data-col="<%= col %>" data-row="<%= row %>"
                   data-center-x="<%= center_x %>"
                   data-center-y="<%= center_y %>"
                   ondragover="allowFleetDrop(event)" 
                   ondrop="handleFleetDrop(event)">
                  
                  <polygon points="<%= points %>" 
                           fill="rgba(0, 123, 255, 0.05)" 
                           stroke="#007bff" 
                           stroke-width="1.5"
                           style="transition: all 0.2s;" />
                  
                  <text x="<%= center_x %>" y="<%= center_y + 14 %>" 
                        class="hex-coord-text" fill="#555" font-size="10" text-anchor="middle" style="user-select: none;">
                    <%= col %>,<%= row %>
                  </text>

                  <% # ハッシュの形式（:col, :row）に合わせて正しく敵データを探す %>
                  <% enemy_session = @enemies.find { |e| e[:col] == col && e[:row] == row } %>
                  <% if enemy_session %>
                    <% enemy_total_hp = enemy_session[:flagship][:hp] + enemy_session[:sub_ships].sum { |s| s[:hp] } %>
                    <% if enemy_total_hp > 0 %>
                      <g style="cursor: help;">
                        <title>
                          <% if enemy_session %>
                            <%# 1. 旗艦のデータを EnemyFreet -> Allfreet の順で安全に取得 %>
                            <% ef_flag = EnemyFreet.find_by(id: enemy_session[:flagship][:id]) %>
                            <% flag_master = ef_flag ? Allfreet.find_by(id: ef_flag.allfreet_id) : nil %>
                            [👑旗艦] <%= flag_master&.name || "敵旗艦" %>: HP <%= enemy_session[:flagship][:hp] %> / <%= enemy_session[:flagship][:max_hp] %>&#10;
    
                            <%# 2. 随伴艦のデータも同様に EnemyFreet -> Allfreet の順で取得 %>
                            <% enemy_session[:sub_ships].each do |s| %>
                              <% ef_sub = EnemyFreet.find_by(id: s[:id]) %>
                              <% sub_master = ef_sub ? Allfreet.find_by(id: ef_sub.allfreet_id) : nil %>
                              ・<%= sub_master&.name || "随伴艦" %>: HP <%= s[:hp] %> / <%= s[:max_hp] %>&#10;
                            <% end %>
                          <% end %>
                        </title>                        
                        <text x="<%= center_x %>" y="<%= center_y - 6 %>" fill="#ff4a4a" font-size="11" font-weight="bold" text-anchor="middle" style="user-select: none;">
                          👾：<%= enemy_session[:name] %>
                        </text>
                        <text x="<%= center_x %>" y="<%= center_y + 8 %>" fill="#ff8888" font-size="9" font-family: monospace; text-anchor="middle" style="user-select: none;">
                          HP <%= enemy_total_hp %>
                        </text>
                      </g>
                    <% end %>
                  <% end %>

                  <% if @allies %>
                    <% ally_session_fleet = @allies.find { |a| a[:col] == col && a[:row] == row } %>
                    <% ally_total_hp = ally_session_fleet ? (ally_session_fleet[:flagship][:hp] + ally_session_fleet[:sub_ships].sum { |s| s[:hp] }) : 0 %>
                    <% if ally_session_fleet && ally_total_hp > 0 %>
                      <g style="cursor: help;">
                        <title><% flag_obj = UserMyfreet.find_by(id: ally_session_fleet[:flagship][:id]) %>[👑旗艦] <%= flag_obj&.allfreet&.name %>: HP <%= ally_session_fleet[:flagship][:hp] %> / <%= ally_session_fleet[:flagship][:max_hp] %>&#10;<% ally_session_fleet[:sub_ships].each do |s| %><% sub_obj = UserMyfreet.find_by(id: s[:id]) %>・<%= sub_obj&.allfreet&.name %>: HP <%= s[:hp] %> / <%= s[:max_hp] %>&#10;<% end %></title>
                        
                        <text x="<%= center_x %>" y="<%= center_y - 6 %>" fill="#00ffbc" font-size="11" font-weight="bold" text-anchor="middle" style="user-select: none;">
                          🚢：<%= ally_session_fleet[:name] %>
                        </text>
                        <text x="<%= center_x %>" y="<%= center_y + 8 %>" fill="#88ffeb" font-size="9" font-family: monospace; text-anchor="middle" style="user-select: none;">
                          HP <%= ally_total_hp %>
                        </text>
                      </g>
                    <% end %>
                  <% end %>
                </g>
              <% end %>
            <% end %>
          </g>
        </svg>
      </div>

      <% if request.path_info == '/battle/set' %>
        <div style="margin-top: 40px;">
          <form id="battleStartForm" action="/battle/start" method="post" style="display: inline-block; margin-right: 10px;">
            <input type="hidden" name="stage" value="<%= @stage %>">
            <input type="hidden" id="input_fleet_1_pos" name="fleet_1_pos" value="">
            <input type="hidden" id="input_fleet_2_pos" name="fleet_2_pos" value="">
            <input type="hidden" id="input_fleet_3_pos" name="fleet_3_pos" value="">
            <input type="hidden" id="input_fleet_4_pos" name="fleet_4_pos" value="">
            <input type="hidden" id="input_fleet_5_pos" name="fleet_5_pos" value="">
            <input type="hidden" id="input_fleet_6_pos" name="fleet_6_pos" value="">

            <button type="submit" style="display: inline-block; background: #ffbc00; color: #000; padding: 10px 20px; border-radius: 5px; border: none; font-weight: bold; font-size: 1em; cursor: pointer; box-shadow: 0 0 10px rgba(255,188,0,0.4);">
              ⚔️ 布陣を確定して戦闘開始！
            </button>
          </form>
        </div>
      <% elsif request.path_info == '/battle/prepare' %>
        <div style="margin-top: 40px;">
          <a href="/home" style="display: inline-block; background: #333; color: #fff; padding: 10px 20px; border-radius: 5px; text-decoration: none; font-weight: bold; border: 1px solid #555;">
            🏳️ 一旦撤退してホームに戻る
          </a>
        </div>
      <% elsif request.path_info == '/battle/start' %>
        <div style="margin-top: 40px;">
          <a href="/home" style="display: inline-block; background: #333; color: #fff; padding: 10px 20px; border-radius: 5px; text-decoration: none; font-weight: bold; border: 1px solid #555;">
            🏳️ 一旦撤退してホームに戻る
          </a>
        </div>
      <% end %>
    </div>
  </main>
  <!-- フェーズごとの特別なオーバーレイ表示 -->
  <% if request.path_info == '/battle/prepare' %>
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(5, 5, 15, 0.9); z-index: 9999; display: flex; flex-direction: column; justify-content: center; align-items: center; backdrop-filter: blur(4px); font-family: monospace;">
    
      <div style="width: 90%; max-width: 600px; background: #111; border: 2px solid #ffbc00; padding: 30px; border-radius: 8px; box-shadow: 0 0 25px rgba(255,188,0,0.3); text-align: center;">
      
        <h1 style="color: #ffbc00; margin-top: 0; font-size: 1.8em; text-transform: uppercase; letter-spacing: 2px; border-bottom: 1px solid #ffbc00; padding-bottom: 15px; margin-bottom: 25px;">
          ⚡ 哨戒戦技発動・準備フェーズ ⚡
        </h1>

        <div style="background: #222; border: 1px solid #444; padding: 20px; border-radius: 6px; text-align: left; max-height: 250px; overflow-y: auto;">
          <h4 style="color: #00ffbc; margin-top: 0; margin-bottom: 10px; border-bottom: 1px solid #333; padding-bottom: 5px;">📜 作戦海域 ログアナウンス</h4>
          <ul style="list-style: none; padding-left: 0; line-height: 1.8; margin: 0; font-size: 1.05em;">
            <% @prep_logs.each do |log| %>
              <li style="margin-bottom: 8px; color: #fff; border-left: 3px solid #ffbc00; padding-left: 10px;">
                <%= log %>
              </li>
            <% end %>
          </ul>
        </div>

        <div style="margin-top: 30px;">
          <a href="/battle/turn" style="display: inline-block; background: #ff4a4a; color: #fff; padding: 12px 35px; border-radius: 4px; text-decoration: none; font-weight: bold; font-size: 1.1em; box-shadow: 0 0 15px rgba(255,74,74,0.4); transition: 0.2s;">
            🚀 進撃開始（戦闘フェーズへ）
          </a>
        </div>
      
      </div>
    </div>
  <% end %>
  <% if request.path_info == '/battle/turn' %>
    <div style="position: fixed; bottom: 20px; left: 20px; width: 400px; background: rgba(15, 10, 10, 0.85); border: 1px solid #ff4a4a; padding: 12px; border-radius: 6px; box-shadow: 0 0 15px rgba(255,74,74,0.3); z-index: 9999; backdrop-filter: blur(3px); font-family: monospace; text-align: left;">
    
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; border-bottom: 1px solid #331111; padding-bottom: 5px;">
        <span style="color: #ff8888; font-weight: bold; font-size: 0.85em; letter-spacing: 1px;">📡 REALTIME BATTLE LOG</span>
        <div>
          <a href="/battle/turn" style="display: inline-block; background: #ffbc00; color: #000; padding: 4px 10px; border-radius: 3px; text-decoration: none; font-weight: bold; font-size: 0.8em; box-shadow: 0 0 8px rgba(255,188,0,0.2); margin-right: 5px; transition: 0.2s;">
            🔄 次のターン
          </a>
          <a href="/home" style="display: inline-block; background: #222; color: #aaa; padding: 4px 8px; border-radius: 3px; text-decoration: none; font-size: 0.8em; border: 1px solid #444;">
            🏳️ 撤退
          </a>
        </div>
      </div>

      <div style="background: rgba(0, 0, 0, 0.6); padding: 8px; border-radius: 4px; max-height: 80px; overflow-y: auto; box-shadow: inset 0 0 5px rgba(0,0,0,0.8);">
        <ul style="list-style: none; padding-left: 0; line-height: 1.4; margin: 0; font-size: 0.85em;">
          <% @turn_logs.each do |log| %>
            <%
              color = "#fff"
              color = "#66ff66" if log.include?("💡") || log.include?("🎉")
              color = "#ff4a4a" if log.include?("🚨") || log.include?("🏳️")
              color = "#ffbc00" if log.include?("⚔️")
            %>
            <li style="margin-bottom: 4px; color: <%= color %>; border-left: 2px solid rgba(255,74,74,0.4); padding-left: 6px; word-break: break-all;">
              <%= log %>
            </li>
          <% end %>
        </ul>
      </div>

    </div>
  <% end %>
</body>
</html>