<div style="max-width: 600px; margin: 40px auto; padding: 20px; background-color: #141414; border: 1px solid #333; border-radius: 8px; color: #fff;">
  <h2>🛡️ 同盟マイページ</h2>
  <h1 style="color: #bae7ff;"><%= @alliance.name %></h1>

  <p>盟主: <strong><%= @alliance.leader.name %></strong></p>

  <hr style="border-color: #2b416d; margin: 20px 0;">

  <h3>👥 所属メンバー一覧</h3>
  <ul>
    <% @alliance.users.each do |member| %>
      <li><%= member.name %> (Lv: <%= member.level %>)</li>
    <% end %>
  </ul>

  <p style="margin-top: 30px;">
    <a href="/home" style="color: #1890ff; text-decoration: none;">➔ ホームに戻る</a>
  </p>

  <div id="chat-preview-bar" style="max-width: 600px; margin: 20px auto; padding: 12px 15px; background-color: #141414; border: 1px solid #2b416d; border-radius: 6px; color: #fff; cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; gap: 10px; align-items: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; flex: 1; font-size: 14px;">
      <span style="color: #52c41a; font-weight: bold; flex-shrink: 0;">🛡️ 同盟チャット:</span>
      <% if @alliance_chats.empty? %>
        <span style="color: #555;">作戦会議を始めましょう！</span>
      <% else %>
        <% last_chat = @alliance_chats.last %>
        <span style="color: #bae7ff; font-weight: bold; flex-shrink: 0;"><%= last_chat.user.name %>:</span>
        <span style="color: #ddd; overflow: hidden; text-overflow: ellipsis;"><%= last_chat.body %></span>
      <% end %>
    </div>
    <span style="color: #666; font-size: 12px; margin-left: 10px; flex-shrink: 0;">開く ➔</span>
  </div>

  <div id="chat-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); z-index: 2000; justify-content: center; align-items: center;">
    <div style="max-width: 600px; width: 90%; padding: 20px; background-color: #141414; border: 1px solid #2b416d; border-radius: 8px; color: #fff; position: relative;">
      
      <button id="chat-close-btn" style="position: absolute; top: 12px; right: 15px; background: none; border: none; color: #aaa; font-size: 22px; cursor: pointer;">✕</button>
      
      <h3 style="margin-top: 0; margin-bottom: 15px; color: #52c41a;">🛡️ 同盟チャット（作戦会議）</h3>

      <div id="chat-history-scroll" style="height: 300px; overflow-y: auto; background-color: #000; padding: 12px; border-radius: 4px; border: 1px solid #222; margin-bottom: 15px;">
        <% if @alliance_chats.empty? %>
          <p style="color: #555; text-align: center; margin-top: 130px;">まだ発言はありません。最初のメッセージをどうぞ！</p>
        <% else %>
          <% @alliance_chats.each do |chat| %>
            <div style="margin-bottom: 10px; font-size: 14px; line-height: 1.4;">
              <span style="color: #bae7ff; font-weight: bold;"><%= chat.user.name %></span>
              <span style="color: #666; font-size: 11px; margin-left: 5px;"><%= chat.created_at.strftime('%m/%d %H:%M') %></span>
              <div style="color: #ddd; margin-left: 10px; word-wrap: break-word;"><%= chat.body %></div>
            </div>
          <% end %>
        <% end %>
      </div>

      <form action="/alliance/chat" method="post" style="display: flex; gap: 10px; margin: 0;">
        <input type="text" name="chat_body" placeholder="同盟メンバーにメッセージを送信" maxlength="100" required 
               style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #444; background: #222; color: #fff;">
        <button type="submit" style="padding: 10px 20px; background-color: #52c41a; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
          送信
        </button>
      </form>
    </div>
  </div>

  <script src="/js/home_chat.js"></script>
</div>