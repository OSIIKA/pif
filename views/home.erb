<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css?v=1">
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>
  <header>
    
  </header>
  <main>
    <div class="user-info">
      <% if @user %>
        <div class="user-name" style="display: flex; align-items: center; gap: 10px;">
          <span id="name-text" style="font-size: 1.2em; font-weight: bold; color: #fff;"><%= @user.name %></span>
          
          <form id="name-edit-form" action="/users/update_name" method="post" style="display: none; align-items: center; gap: 5px; margin: 0;">
            <input type="text" name="name" value="<%= @user.name %>" required maxlength="20" style="background: #222; color: #fff; border: 1px solid #555; padding: 5px 10px; border-radius: 4px; font-size: 1em;">
            <button type="submit" style="background-color: #1890ff; color: #fff; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-weight: bold;">保存</button>
            <button type="button" id="cancel-name-btn" style="background-color: #555; color: #fff; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">取消</button>
          </form>

          <button type="button" id="edit-name-btn" style="background: transparent; border: none; color: #1890ff; cursor: pointer; font-size: 0.9em; padding: 0;">[編集]</button>
        </div>
        <div class="user-stats">
          <span class="stat">Lv:<%= @user.level %></span>
          <span class="stat">Exp:<%= @user.exp %></span>
        </div>
        <%
          # 🟢 大倉さん設計準拠：名前は使わず、type: 0, rarity: 1 で「紫鉄」を狙い撃ちして取得
          iron_item = Item.find_by(type: 0, rarity: 1)
          user_iron = iron_item ? @user.user_items.find_by(item_id: iron_item.id) : nil
          iron_count = user_iron ? user_iron.count : 0
        %>
        <div style="font-weight: bold; margin-bottom: 10px;">
  
          <span style="margin-left: 20px; background: #222; border: 1px solid #555; padding: 2px 8px; border-radius: 4px; color: #ffbc00;">
            🔩 紫鉄: <strong style="font-size: 1.1em; color: #fff;"><%= iron_count %></strong> 個
          </span>
        </div>
      <% else %>
        <p>ログインしてください</p>
      <% end %>
    </div>

    <button id="open-encyclopedia-btn" style="padding: 10px 20px; background: #1890ff; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
      🚢 艦艇図鑑を開く
    </button>

    <div id="encyclopedia-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); z-index: 1000; justify-content: center; align-items: center;">
      <div style="background: #222; width: 80%; height: 80%; border-radius: 8px; padding: 20px; display: flex; flex-direction: column; color: #fff; position: relative;">
          
        <button id="close-encyclopedia-btn" style="position: absolute; top: 15px; right: 15px; background: none; border: none; color: #aaa; font-size: 1.5em; cursor: pointer;">&times;</button>
          
        <h2 style="margin-top: 0; border-bottom: 1px solid #444; padding-bottom: 10px;">⚓ 艦艇図鑑</h2>
          
        <!-- 1段階目: 艦艇一覧 -->
        <div id="encyclopedia-list" style="flex: 1; overflow-y: auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; padding: 10px 0;">
        </div>
          
        <!-- 2段階目: 艦艇詳細 (図鑑の中に引っ越し、初期値は display: none で非表示化) -->
        <div id="ship-detail-content" style="display: none; gap: 20px; min-height: 300px; flex: 1; margin-top: 10px; flex-direction: column;">
            
          <button id="detail-back-btn" style="align-self: flex-start; padding: 8px 16px; background-color: #555; color: #fff; border: none; border-radius: 4px; cursor: pointer; margin-bottom: 10px; font-weight: bold;">← 戻る</button>

          <div id="detail-main-panel" style="flex: 1;">
          </div>

          <div id="detail-tab-sidebar" style="display: flex; flex-direction: column; gap: 10px; border-left: 1px solid #444; padding-left: 15px; justify-content: flex-start;">
            <button class="detail-tab-btn active" data-tab="status" style="padding: 10px; background: #333; color: #fff; border: 1px solid #555; border-radius: 4px; cursor: pointer; white-space: nowrap;">📊 ステータス</button>
            <button class="detail-tab-btn" data-tab="gacha" style="padding: 10px; background: #222; color: #aaa; border: 1px solid #333; border-radius: 4px; cursor: pointer; white-space: nowrap;">🎲 入手方法</button>
          </div>

        </div>

      </div>
    </div>

    <a href="/alliance" style="display: inline-block; padding: 10px 20px; background-color: #52c41a; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; margin: 5px;">
      🛡️ 同盟
    </a>
    <a href="/gacha" style="display: inline-block; padding: 10px 20px; background-color: #1890ff; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; margin: 5px;">
      🎲 ガチャ
    </a>
    <a href="/base" style="display: inline-block; padding: 12px 30px; background-color: #434343; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold;">
      🏢 基地
    </a>
    <a href="/fleet" style="display: inline-block; padding: 12px 30px; background-color: #096dd9; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold;">
      ⚓ 艦隊
    </a>
    
    <form action="/home/freet" method="post">
      <input type="text" name="name" placeholder="艦名">
      <input type="int" name="hp" placeholder="HP">
      <input type="int" name="atk" placeholder="攻撃">
      <input type="text" name="info" placeholder="情報">
      <input type="submit" value="新規登録">
    </form>
    <button id="toggle-storys">表示する</button>
    <div class="storys" style="display: none;">
      <form action="/home/battle" method="post">
        <button type="submit" name="story" value="0">バトル</button>
        <button type="submit" name="story" value="1">バトル</button>
      </form>
      <form action="/home/story" method="post">
        <!input type="submit" value="第0話">
        <button type="submit" name="story" value="0">第0話</button>
        <button type="submit" name="story" value="1">第1話</button>
      </form>
    </div>
    
    <button id="toggle-units">表示する</button>
    <div class="units" style="display: none;">
      <% @freets.each do |freet| %>
        <div class="unit">
          <p><%= freet['allfreet']['name'] %></p>
          <p>Lv：<%= freet['level'] %>Exp：<%= freet['exp'] %></p>
          <p>HP：<%= freet['allfreet']['max_hp'] %></p>
          <p>攻撃：<%= freet['allfreet']['atk'] %></p>
          <p>情報：<%= freet['allfreet']['info'] %></p>
          <form action="/home/levelup" method="post">
            <input type="hidden" name="unit_id" value="<%= freet['id'] %>">
            <button type="submit">レベルアップ</button>
          </form>
        </div>
      <% end %>
    </div>
    <div id="sortie-overlay" class="sortie-overlay">
      <div class="sortie-overlay-content">
        <h2>出撃メニュー</h2>
        <button class="sortie-menu-button" data-mode="story">ストーリー（バトル含む）</button>
        <button class="sortie-menu-button" data-mode="battle">バトル（素材集め）</button>
        <button class="sortie-menu-button" data-mode="event">イベント（準備中）</button>
        <button id="sortie-close" class="sortie-close-button">閉じる</button>
      </div>
    </div>
    <div id="story-overlay" class="story-overlay">
      <div class="story-overlay-content">
        <h2>ストーリー選択</h2>
        <form action="/home/story" method="post">
          <button type="submit" name="story" value="0" class="story-button">第0話（バトル）</button>
          <button type="submit" name="story" value="1" class="story-button">第1話（バトル）</button>
        </form>
        <button id="story-close" class="story-close-button">閉じる</button>
      </div>
    </div>
    <div id="event-overlay" class="sortie-overlay" style="display: none;">
      <div class="sortie-overlay-content">
        <h2>イベント選択</h2>
        <div class="event-list" style="margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px; align-items: center;">
          <% if @personal_events.empty? && @alliance_events.empty? %>
            <p style="color: #aaa;">現在開催中のイベントはありません</p>
          <% else %>
            <% @personal_events.each do |evt| %>
              <button class="story-button" data-event-id="<%= evt[:id] %>" style="background-color: #722ed1; color: #fff;"><%= evt[:name] %></button>
            <% end %>
            <% @alliance_events.each do |evt| %>
              <button class="story-button" data-event-id="<%= evt[:id] %>" style="background-color: #389e0d; color: #fff;"><%= evt[:name] %></button>
            <% end %>
          <% end %>
        </div>
        <button id="event-close" class="sortie-close-button">戻る</button>
      </div>
    </div>
    <button id="sortie-button" class="sortie-button">出撃</button>

    <div id="chat-preview-bar" style="max-width: 600px; margin: 20px auto; padding: 12px 15px; background-color: #141414; border: 1px solid #333; border-radius: 6px; color: #fff; cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: background 0.2s;">
      <div style="display: flex; gap: 10px; align-items: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; flex: 1; font-size: 14px;">
        <span style="color: #1890ff; font-weight: bold; flex-shrink: 0;">💬 全体チャット:</span>
        <% if @global_chats.empty? %>
          <span style="color: #555;">まだ発言はありません。</span>
        <% else %>
          <% last_chat = @global_chats.last %>
          <span style="color: #52c41a; font-weight: bold; flex-shrink: 0;"><%= last_chat.user.name %>:</span>
          <span style="color: #ddd; overflow: hidden; text-overflow: ellipsis;"><%= last_chat.body %></span>
        <% end %>
      </div>
      <span style="color: #666; font-size: 12px; margin-left: 10px; flex-shrink: 0;">タップして開く ➔</span>
    </div>

    <div id="chat-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); z-index: 2000; justify-content: center; align-items: center;">
      <div style="max-width: 600px; width: 90%; padding: 20px; background-color: #141414; border: 1px solid #333; border-radius: 8px; color: #fff; position: relative; box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
    
        <button id="chat-close-btn" style="position: absolute; top: 12px; right: 15px; background: none; border: none; color: #aaa; font-size: 22px; cursor: pointer; padding: 5px;">✕</button>
    
        <h3 style="margin-top: 0; margin-bottom: 15px; color: #1890ff;">💬 日本語全体チャット</h3>

        <div id="chat-history-scroll" style="height: 300px; overflow-y: auto; background-color: #000; padding: 12px; border-radius: 4px; border: 1px solid #222; margin-bottom: 15px;">
          <% if @global_chats.empty? %>
            <p style="color: #555; text-align: center; margin-top: 130px;">まだ発言はありません。最初のメッセージをどうぞ！</p>
          <% else %>
            <% @global_chats.each do |chat| %>
              <div style="margin-bottom: 10px; font-size: 14px; line-height: 1.4;">
                <span style="color: #52c41a; font-weight: bold;"><%= chat.user.name %></span>
                <span style="color: #666; font-size: 11px; margin-left: 5px;"><%= chat.created_at.strftime('%m/%d %H:%M') %></span>
                <div style="color: #ddd; margin-left: 10px; word-wrap: break-word;"><%= chat.body %></div>
              </div>
            <% end %>
          <% end %>
        </div>

        <form action="/home/chat" method="post" style="display: flex; gap: 10px; margin: 0;">
          <input type="text" name="chat_body" placeholder="メッセージを入力（最大100文字）" maxlength="100" required 
                style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #444; background: #222; color: #fff; font-size: 14px;">
          <button type="submit" style="padding: 10px 20px; background-color: #1890ff; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 14px;">
            送信
          </button>
        </form>
      </div>
    </div>
  </main>
  <script src="/js/home.js"></script>
  <script src="/js/home_chat.js"></script>
</body>
</html>