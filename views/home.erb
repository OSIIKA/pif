<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css?v=1">
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>
  <header>
    
  </header>
  <main>
    <div class="user-info">
      <% if @user %>
        <div class="user-name">
          <%= @user.name %>
        </div>
        <div class="user-stats">
          <span class="stat">Lv:<%= @user.level %></span>
          <span class="stat">Exp:<%= @user.exp %></span>
        </div>
      <% else %>
        <p>ログインしてください</p>
      <% end %>
    </div>
    <a href="/alliance" style="display: inline-block; padding: 10px 20px; background-color: #52c41a; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; margin: 5px;">
      🛡️ 同盟
    </a>
    
    <form action="/home/freet" method="post">
      <input type="text" name="name" placeholder="艦名">
      <input type="int" name="hp" placeholder="HP">
      <input type="int" name="atk" placeholder="攻撃">
      <input type="text" name="info" placeholder="情報">
      <input type="submit" value="新規登録">
    </form>
    <button id="toggle-storys">表示する</button>
    <div class="storys" style="display: none;">
      <form action="/home/battle" method="post">
        <button type="submit" name="story" value="0">バトル</button>
        <button type="submit" name="story" value="1">バトル</button>
      </form>
      <form action="/home/story" method="post">
        <!input type="submit" value="第0話">
        <button type="submit" name="story" value="0">第0話</button>
        <button type="submit" name="story" value="1">第1話</button>
      </form>
    </div>
    
    <button id="toggle-units">表示する</button>
    <div class="units" style="display: none;">
      <% @freets.each do |freet| %>
        <div class="unit">
          <p><%= freet['myfreet']['name'] %></p>
          <p>Lv：<%= freet['level'] %>Exp：<%= freet['exp'] %></p>
          <p>HP：<%= freet['myfreet']['hp'] %></p>
          <p>攻撃：<%= freet['myfreet']['atk'] %></p>
          <p>情報：<%= freet['myfreet']['info'] %></p>
          <form action="/home/levelup" method="post">
            <input type="hidden" name="unit_id" value="<%= freet['id'] %>">
            <button type="submit">レベルアップ</button>
          </form>
        </div>
      <% end %>
    </div>
    <div id="sortie-overlay" class="sortie-overlay">
      <div class="sortie-overlay-content">
        <h2>出撃メニュー</h2>
        <button class="sortie-menu-button" data-mode="story">ストーリー（バトル含む）</button>
        <button class="sortie-menu-button" data-mode="battle">バトル（素材集め）</button>
        <button class="sortie-menu-button" data-mode="event">イベント（準備中）</button>
        <button id="sortie-close" class="sortie-close-button">閉じる</button>
      </div>
    </div>
    <div id="story-overlay" class="story-overlay">
      <div class="story-overlay-content">
        <h2>ストーリー選択</h2>
        <form action="/home/story" method="post">
          <button type="submit" name="story" value="0" class="story-button">第0話（バトル）</button>
          <button type="submit" name="story" value="1" class="story-button">第1話（バトル）</button>
        </form>
        <button id="story-close" class="story-close-button">閉じる</button>
      </div>
    </div>
    <button id="sortie-button" class="sortie-button">出撃</button>
    <div style="max-width: 600px; margin: 30px auto; padding: 20px; background-color: #141414; border: 1px solid #333; border-radius: 8px; color: #fff;">
      <h3>💬 日本語全体チャット</h3>

      <div style="height: 250px; overflow-y: auto; background-color: #000; padding: 10px; border-radius: 4px; border: 1px solid #222; margin-bottom: 15px;">
        <% if @global_chats.empty? %>
          <p style="color: #555; text-align: center; margin-top: 100px;">まだ発言はありません。最初のメッセージをどうぞ！</p>
        <% else %>
          <% @global_chats.each do |chat| %>
            <div style="margin-bottom: 8px; font-size: 14px; line-height: 1.4;">
              <span style="color: #52c41a; font-weight: bold;"><%= chat.user.name %></span>
              <span style="color: #666; font-size: 11px; margin-left: 5px;"><%= chat.created_at.strftime('%m/%d %H:%M') %></span>
              <div style="color: #ddd; margin-left: 10px; word-wrap: break-word;"><%= chat.body %></div>
            </div>
          <% end %>
        <% end %>
      </div>

      <form action="/home/chat" method="post" style="display: flex; gap: 10px;">
        <input type="text" name="chat_body" placeholder="メッセージを入力（最大100文字）" maxlength="100" required 
              style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #444; background: #222; color: #fff;">
        <button type="submit" style="padding: 10px 20px; background-color: #1890ff; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
          送信
        </button>
      </form>
    </div>
  </main>
  <script src="/js/home.js"></script>
</body>
</html>