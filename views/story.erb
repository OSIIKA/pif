<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div>
      <h1>紫鉄艦隊</h1>
    </div>
  </header>
  <main>
    <!-- ストーリー操作ボタン（右上固定） -->
    <div class="story-ui">
      <button class="story-ui-button" id="skip-button" onclick="location.href='/story/skip'">
        スキップ
      </button>
      <button class="story-ui-button" id="log-button">ログ</button>
      <button class="story-ui-button" id="auto-button">オート</button>
    </div>
    <div class="message-window">
      <div class="speaker-name">
        <%= @name %>
      </div>
      <div class="message-text">
        <%= @text %>
      </div>
    </div>
  </main>
  <script>
    document.addEventListener('click', function(e) {
      // メッセージウィンドウ内のクリックは許可（次へ進む）
      // UI ボタンを押したときは次へ進まない
      if (e.target.closest('.story-ui-button')) {
        return;
      }

      // 次のメッセージへ
      window.location.href = "/story";
    });
  </script>

</body>
</html>