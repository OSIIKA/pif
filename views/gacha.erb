<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>ガチャ - 紫鉄艦隊</title>
</head>
<body>

    <h1>🎲 ガチャシステム</h1>
    <%
      # 🔩 大倉さん設計準拠：紫鉄 (type: 0, rarity: 1) の所持数を取得
      iron_item = Item.find_by(type: 0, rarity: 1)
      user_iron = (iron_item && @user) ? @user.user_items.find_by(item_id: iron_item.id) : nil
      iron_count = user_iron ? user_iron.count : 0

      # 🎟️ 現在おまけで配られているはずの「ID: 3」のアイテム（期間限定ガチャチケット）の所持数を取得
      ticket_item = Item.find_by(id: 3)
      user_ticket = (ticket_item && @user) ? @user.user_items.find_by(item_id: ticket_item.id) : nil
      ticket_count = user_ticket ? user_ticket.count : 0
      ticket_name = ticket_item ? ticket_item.name : "期間限定ガチャチケット"
    %>

    <div style="background: #222; border: 1px solid #444; padding: 10px 15px; border-radius: 6px; margin-bottom: 15px; display: inline-flex; gap: 20px; font-weight: bold;">
      <span style="color: #fff;">
        🔩 紫鉄: <strong style="color: #ffbc00; font-size: 1.1em;"><%= iron_count %></strong> 個
      </span>
      <span style="color: #fff; border-left: 1px solid #555; padding-left: 20px;">
        🎟️ <%= ticket_name %>: <strong style="color: #ffbc00; font-size: 1.1em;"><%= ticket_count %></strong> 枚
      </span>
    </div>
    <div style="display: flex; gap: 15px; margin: 25px 0;">
  
      <form action="/gacha/<%= @gacha_type %>" method="post" style="margin: 0;">
        <input type="hidden" name="roll_count" value="1">
        <button type="submit" style="padding: 12px 25px; background-color: #1890ff; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
          🚀 ガチャを1回引く
        </button>
      </form>

      <form action="/gacha/<%= @gacha_type %>" method="post" style="margin: 0;">
        <input type="hidden" name="roll_count" value="10">
        <button type="submit" style="padding: 12px 25px; background-color: #722ed1; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
          🔥 10連ガチャを引く
        </button>
      </form>

    </div>
    <%
      # 1. まず、そのガチャにおける各大枠レア度（RARITY）の基本確率を設定
      if @gacha_type == "rare"
        rarity_rates = { 3 => 5.0, 2 => 20.0, 1 => 75.0 } # SSR 5%, R 20%, N 75%
        weight_column = "rare"
      else
        rarity_rates = { 3 => 0.0, 2 => 10.0, 1 => 90.0 } # SSR 0%, R 10%, N 90%
        weight_column = "normal"
      end

      # 2. 現在排出対象になっている（重みが0より大きい）キャラクターを全取得
      display_candidates = Allfreet.where("#{weight_column} > 0")
    %>

    <div style="text-align: right; margin: -10px 0 15px 0;">
      <button onclick="openProbability()" style="background: none; border: none; color: #aaa; text-decoration: underline; cursor: pointer; font-size: 0.9em;">
        📊 この作戦の提供割合（排出確率）を確認する
      </button>
    </div>

    <div id="probability-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0, 0, 0, 0.85); display: none; align-items: center; justify-content: center; z-index: 2000;">
      <div style="background: #222; border: 2px solid #d4b106; padding: 25px; border-radius: 8px; width: 90%; max-width: 450px; text-align: center;">
      
        <h3 style="color: #d4b106; margin-top: 0; margin-bottom: 5px;">📜 提供割合（<%= @gacha_type == 'rare' ? 'レアガチャ' : '通常ガチャ' %>）</h3>
        <p style="font-size: 0.8em; color: #aaa; margin-bottom: 15px;">※景品表示法及びガイドラインに基づき、算出確率を公開しています。</p>

        <div style="max-height: 250px; overflow-y: auto; margin-bottom: 20px; border: 1px solid #444; border-radius: 4px;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95em;">
            <thead style="background: #333; color: #fff; position: sticky; top: 0;">
              <tr>
                <th style="padding: 8px;">艦船名 (レア度)</th>
                <th style="padding: 8px; text-align: right;">排出確率</th>
              </tr>
            </thead>
            <tbody>
              <% display_candidates.each do |ship| %>
                <% 
                  # 🟢 ここが2段階抽選用の計算！
                  # 同じレア度の中に、現在何人の排出対象キャラがいるかを数える（分母）
                  same_rarity_count = display_candidates.where(rarity: ship.rarity).count
                
                  if same_rarity_count > 0
                    # 大枠の確率 ÷ そのレア度のキャラ数 で、1隻あたりの確率を完全に等分（圧縮）する！
                    base_rate = rarity_rates[ship.rarity] || 0.0
                    percent = (base_rate / same_rarity_count).round(2)
                  else
                    percent = 0.0
                  end
                  # 🟢 【この1行を追加！】確率が 0.0% のキャラは表示をスキップして次のループへ進む
                  next if percent == 0.0
                %>
                <tr style="border-bottom: 1px solid #333; color: #fff;">
                  <td style="padding: 8px;">
                    <span style="color: #deff9a;">[<%= ship.rarity_text %>]</span> <%= ship.name %>
                  </td>
                  <td style="padding: 8px; text-align: right; font-weight: bold; color: #deff9a;">
                    <%= percent %>%
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <button onclick="closeProbability()" style="padding: 8px 25px; background: #444; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
          ✖ 閉じる
        </button>
      </div>
    </div>

    <script>
      function openProbability() {
        document.getElementById('probability-overlay').style.display = 'flex';
      }
      function closeProbability() {
        document.getElementById('probability-overlay').style.display = 'none';
      }
    </script>

    <hr class="hr">

    <% if @gacha_type == "rare" || @gacha_type == "limited" %>
      <%
        # 🟢 大倉さん設計：名前は一切使わず、type: 2 (シール) と rarity: 1 (レア用) で特定！
        seal_item = Item.find_by(type: 2, rarity: 1)
        user_seal = seal_item ? @user.user_items.find_by(item_id: seal_item.id) : nil
        seal_count = user_seal ? user_seal.count : 0

        # 10枚で天井交換できるテスト設定
        exchange_limit = 10 
      %>

      <div style="background: #1a1a1a; border: 1px solid #444; padding: 15px; border-radius: 6px; margin: 15px 0; color: #fff;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <span style="color: #6495ed; font-weight: bold;">🎟️ 現在の<%= seal_item ? seal_item.name : "ガチャシール" %>:</span>
            <span style="font-size: 1.3em; color: #fff; font-weight: bold; margin-left: 5px;"><%= seal_count %></span> 枚
            <p style="margin: 5px 0 0 0; font-size: 0.8em; color: #aaa;">※<%= exchange_limit %>枚貯まると、特別に[SR]味方3を直接召喚（天井交換）できます！</p>
          </div>
        
          <% if seal_count >= exchange_limit %>
            <form action="/gacha/exchange" method="post" style="margin: 0; display: flex; gap: 10px; align-items: center;">
              <input type="hidden" name="gacha_type" value="<%= @gacha_type %>">
            
              <%
                # 🟢 大倉さん新設計：名前は一切使わず、レア度3（SR）以上のキャラをDBから全自動で拉致してくる！
                pickup_characters = Allfreet.where("rarity >= ?", 3)
              %>
            
              <select name="target_character_id" style="background: #333; color: #fff; border: 1px solid #555; padding: 10px; border-radius: 4px; font-weight: bold;">
                <% pickup_characters.each do |char| %>
                  <% 
                    # 敵キャラ（名前に"敵"や"Mk."が入っている場合）は赤、味方は青のアイコンにする演出
                    prefix = (char.name.include?("敵") || char.name.include?("Mk.")) ? "🔴" : "🔵"
                  %>
                  <option value="<%= char.id %>">
                  <%= prefix %> [SR] <%= char.name %> を召喚する
                  </option>
                <% end %>
              </select>

              <button type="submit" style="background: #d4b106; color: #000; border: none; padding: 10px 15px; border-radius: 4px; font-weight: bold; cursor: pointer; border-bottom: 3px solid #9a8003;">
                🤝 天井交換を発動！
              </button>
            </form>
          <% else %>
            <button disabled style="background: #444; color: #888; border: none; padding: 10px 15px; border-radius: 4px; font-weight: bold; cursor: not-allowed;">
              🔒 払い出しまであと <%= exchange_limit - seal_count %> 枚
            </button>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @gacha_type == "limited" %>
      <button type="button" onclick="openBonusModal()" style="background: #333; color: #ffbc00; border: 1px solid #ffbc00; padding: 8px 12px; border-radius: 4px; font-weight: bold; cursor: pointer; margin-bottom: 15px;">
        🎁 10連おまけ報酬一覧を見る
      </button>

      <div id="bonusModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); z-index: 9999; justify-content: center; align-items: center;">
        <div style="background: #1a1a1a; color: #fff; border: 2px solid #555; padding: 20px; border-radius: 8px; width: 90%; max-width: 360px; box-shadow: 0 4px 20px rgba(0,0,0,0.8);">
    
          <h3 style="margin-top: 0; border-bottom: 2px solid #ffbc00; padding-bottom: 10px; color: #ffbc00; text-align: center;">
            🚀 10連ガチャ 累計ボーナス
          </h3>
    
          <ul style="list-style: none; padding: 0; margin: 15px 0; max-height: 300px; overflow-y: auto;">
            <%
              # 1. タイムラインから「ガチャ関連おまけ(1, 1)」を全取得
              display_bonuses = Itemtimeline.where(big_type: 1, small_type: 1).order(:step)
        
              # 👤 2. 大倉さん新設のテーブルから、現在のユーザーの実際のステップ数を取得（データがなければ1）
              current_step = @user.usersteps ? @user.usersteps.limited_gacha_step : 1

              # 🔄 3. 大倉さん新提案のソートロジック
              # [獲得済み(true=1, false=0), ステップ番号] で並び替えることで、
              # 未獲得（0）が上、獲得済み（1）が下になりつつ、それぞれのグループ内はステップ順に綺麗に並びます
              sorted_bonuses = display_bonuses.sort_by { |b| [b.step < current_step ? 1 : 0, b.step] }

              sorted_bonuses.each do |bonus|
                target_item = Item.find_by(id: bonus.item_id)
                item_name = target_item ? target_item.name : "未知の物質"
          
                # 🔍 獲得済みかどうかの判定フラグ
                is_earned = bonus.step < current_step
          
                # 🎨 獲得状態によって色（デザイン）を動的に切り替える
                text_color = is_earned ? "#555555" : "#ffffff"       # 獲得済みは暗いグレー、未は白
                count_color = is_earned ? "#444444" : "#ffbc00"      # 獲得済みはさらに暗い、未はゴールド
                bg_color = is_earned ? "rgba(0,0,0,0.2)" : "transparent" # 獲得済みは背景も少し暗く
            %>
              <li style="padding: 10px 8px; border-bottom: 1px solid #333; display: flex; justify-content: space-between; font-size: 0.95em; background: <%= bg_color %>; border-radius: 4px;">
                <span style="color: <%= text_color %>;">
                  <strong><%= bonus.step %>回目：</strong> <%= item_name %>
                  <% if is_earned %>
                    <span style="font-size: 0.8em; margin-left: 5px; color: #444;">(獲得済み)</span>
                  <% end %>
                </span>
                <span style="color: <%= count_color %>; font-weight: bold;"><%= bonus.count %> 個</span>
              </li>
            <% end %>
          </ul>
    
          <button type="button" onclick="closeBonusModal()" style="background: #444; color: #fff; border: none; padding: 10px; border-radius: 4px; cursor: pointer; width: 100%; font-weight: bold; margin-top: 10px;">
            閉じる
          </button>
    
        </div>
      </div>

      <script>
        function openBonusModal() {
          document.getElementById('bonusModal').style.display = 'flex';
        }
        function closeBonusModal() {
          document.getElementById('bonusModal').style.display = 'none';
        }
      </script>
    <% end %>

    <div class="gacha">

      <div class="gacha-types">
        <h3 style="margin-top: 0; margin-bottom: 15px; color: #1890ff; border-bottom: 1px solid #333; padding-bottom: 8px; font-size: 1em; letter-spacing: 1px;">
          🛸 作戦（ガチャ）選択
        </h3>
        
        <div style="display: flex; flex-direction: column; gap: 10px;">
          <a href="/gacha?type=normal" style="display: block; width: 100%; padding: 12px; background-color: <%= @gacha_type == 'normal' ? '#1890ff' : '#222' %>; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; margin-bottom: 10px; box-sizing: border-box;">
            🔵 通常ガチャ <%= @gacha_type == 'normal' ? '◀選択中' : '' %>
          </a>

          <a href="/gacha?type=rare" style="display: block; width: 100%; padding: 12px; background-color: <%= @gacha_type == 'rare' ? '#d4b106' : '#222' %>; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; margin-bottom: 10px; box-sizing: border-box;">
            🟡 レアガチャ起動 <%= @gacha_type == 'rare' ? '◀選択中' : '' %>
          </a>
          
          <a href="/gacha?type=limited" style="display: block; width: 100%; padding: 12px; background-color: <%= @gacha_type == 'limited' ? '#d4b106' : '#222' %>; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; margin-bottom: 10px; box-sizing: border-box;">
            🎃 期間限定ガチャ起動 <%= @gacha_type == 'limited' ? '◀選択中' : '' %>
          </a>
          
          <button style="padding: 10px; background: #262626; color: #aaa; border: 1px solid #434343; border-radius: 4px; font-weight: bold; text-align: left; cursor: not-allowed;">
            👑 ストーリークリアガチャ (準備中)
          </button>
          
          <button style="padding: 10px; background: #262626; color: #aaa; border: 1px solid #434343; border-radius: 4px; font-weight: bold; text-align: left; cursor: not-allowed;">
            ✨ イベントガチャ (準備中)
          </button>
        </div>
      </div>

      <div class="gacha-cards">

        <% if @rolled_ship %>
          <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0, 0, 0, 0.85); display: flex; align-items: center; justify-content: center; z-index: 1000;">
            <div style="background: #222; border: 2px solid #deff9a; padding: 25px; border-radius: 8px; text-align: center; min-width: 300px;">
              <h2 style="color: #deff9a; margin-top: 0;">🎉 艦船 召喚成功！</h2>
              <table style="width: 100%; text-align: left; margin-bottom: 20px;">
                <tr><td style="color:#fff; font-size:1.2em; font-weight:bold;"><%= @rolled_ship.rarity_text %> : <%= @rolled_ship.name %></td></tr>
                <tr><td style="color:#aaa;">HP: <%= @rolled_ship.max_hp %> / ATK: <%= @rolled_ship.atk %></td></tr>
              </table>
              <a href="/gacha" style="display: inline-block; padding: 8px 24px; background: #444; color: #fff; text-decoration: none; border-radius: 4px;">✖ 閉じる</a>
            </div>
          </div>
        <% end %>


        <% if @rolled_ships && @rolled_ships.any? %>
          <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0, 0, 0, 0.9); display: flex; align-items: center; justify-content: center; z-index: 1000;">
            
            <% @rolled_ships.each_with_index do |ship, index| %>
              <div class="gacha-card" style="background: #222; border: 2px solid #deff9a; padding: 25px; border-radius: 8px; text-align: center; min-width: 300px; display: <%= index == 0 ? 'block' : 'none' %>;">
                <span style="color: #888;">【 <%= index + 1 %> / 10 隻目 】</span>
                <h2 style="color: #deff9a; margin-top: 10px;">🎉 艦船 召喚成功！</h2>
                <table style="width: 100%; text-align: left; margin-bottom: 20px;">
                  <tr><td style="color:#fff; font-size:1.2em; font-weight:bold;"><%= ship.rarity_text %> : <%= ship.name %></td></tr>
                  <tr><td style="color:#aaa;">HP: <%= ship.max_hp %> / ATK: <%= ship.atk %></td></tr>
                </table>
                <button onclick="nextCard()" style="padding: 10px 20px; background: #722ed1; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
                  👉 次へ
                </button>
              </div>
            <% end %>

            <div id="final-summary" style="background: #1f1f1f; border: 2px solid #722ed1; padding: 30px; border-radius: 12px; text-align: center; width: 90%; max-width: 600px; display: none;">
              <h2 style="color: #722ed1; margin-top: 0;">📊 今回の召喚結果一覧</h2>
              
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; text-align: left; margin-bottom: 25px; max-height: 300px; overflow-y: auto; padding: 5px;">
                <% @rolled_ships.each do |ship| %>
                  <div style="background: #2d2d2d; padding: 8px; border-radius: 4px; border-left: 3px solid #deff9a;">
                    <span style="color: #deff9a; font-weight: bold;">[<%= ship.rarity_text %>]</span> <span style="color: #fff;"><%= ship.name %></span>
                  </div>
                <% end %>
              </div>

              <a href="/gacha" style="display: inline-block; padding: 10px 30px; background: #444; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold;">
                ✖ 閉じる
              </a>
            </div>

          </div>

          <script src="/js/gacha.js"></script>
        <% end %>


        <% if !@rolled_ship && (!@rolled_ships || @rolled_ships.empty?) %>
          <div style="border: 1px dashed #444; padding: 30px; text-align: center; color: #666; border-radius: 6px;">
            左の作戦を選択し、上のボタンを押すと、登録されたマスターデータからランダムに1隻が選出されます。
          </div>
        <% end %>

      </div>

    </div>

    <br><br>
    <a href="/home" style="color: #1890ff; text-decoration: none; font-size: 0.95em;">➔ ホームに戻る</a>

</body>
</html>