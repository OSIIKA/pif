<div style="max-width: 600px; margin: 40px auto; padding: 20px; background-color: #141414; border: 1px solid #333; border-radius: 8px; color: #fff;">
  
  <% if session[:error] %>
    <div style="background-color: #ff4d4f; color: #fff; padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 14px;">
      ⚠️ <%= session[:error] %><% session[:error] = nil %>
    </div>
  <% end %>

  <h2>🛡️ 同盟マイページ</h2>
  
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
    <h1 style="color: #bae7ff; margin: 0;"><%= @alliance.name %></h1>
    <button id="menu-open-btn" style="background: #222; border: 1px solid #444; color: #fff; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold; transition: background 0.2s;">
      ⚙️ メニュー
    </button>
  </div>

  <p>盟主: <strong><%= @alliance.leader.name %></strong> | レベル: <%= @alliance.level %> | EXP: <%= @alliance.exp %></p>

  <hr style="border-color: #2b416d; margin: 20px 0;">

  <h3>👥 所属メンバー一覧</h3>
  <ul>
    <% @alliance.users.each do |member| %>
      <li>
        <strong>[<%= member.alliance_role_name %>]</strong> 
        <%= member.name %> (Lv: <%= member.level %>)
      </li>
    <% end %>
  </ul>

  <p style="margin-top: 30px;">
    <a href="/home" style="color: #1890ff; text-decoration: none;">➔ ホームに戻る</a>
  </p>

  <div id="chat-preview-bar" style="max-width: 600px; margin: 20px auto; padding: 12px 15px; background-color: #141414; border: 1px solid #2b416d; border-radius: 6px; color: #fff; cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; gap: 10px; align-items: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; flex: 1; font-size: 14px;">
      <span style="color: #52c41a; font-weight: bold; flex-shrink: 0;">🛡️ 同盟チャット:</span>
      <% if @alliance_chats.empty? %>
        <span style="color: #555;">作戦会議を始めましょう！</span>
      <% else %>
        <% last_chat = @alliance_chats.last %>
        <span style="color: #bae7ff; font-weight: bold; flex-shrink: 0;"><%= last_chat.user.name %>:</span>
        <span style="color: #ddd; overflow: hidden; text-overflow: ellipsis;"><%= last_chat.body %></span>
      <% end %>
    </div>
    <span style="color: #666; font-size: 12px; margin-left: 10px; flex-shrink: 0;">開く ➔</span>
  </div>

  <div id="chat-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); z-index: 2000; justify-content: center; align-items: center;">
    <div style="max-width: 600px; width: 90%; padding: 20px; background-color: #141414; border: 1px solid #2b416d; border-radius: 8px; color: #fff; position: relative;">
      <button id="chat-close-btn" style="position: absolute; top: 12px; right: 15px; background: none; border: none; color: #aaa; font-size: 22px; cursor: pointer;">✕</button>
      <h3 style="margin-top: 0; margin-bottom: 15px; color: #52c41a;">🛡️ 同盟チャット（作戦会議）</h3>
      <div id="chat-history-scroll" style="height: 300px; overflow-y: auto; background-color: #000; padding: 12px; border-radius: 4px; border: 1px solid #222; margin-bottom: 15px;">
        <% if @alliance_chats.empty? %>
          <p style="color: #555; text-align: center; margin-top: 130px;">まだ発言はありません。最初のメッセージをどうぞ！</p>
        <% else %>
          <% @alliance_chats.each do |chat| %>
            <div style="margin-bottom: 10px; font-size: 14px; line-height: 1.4;">
              <span style="color: #bae7ff; font-weight: bold;"><%= chat.user.name %></span>
              <span style="color: #666; font-size: 11px; margin-left: 5px;"><%= chat.created_at.strftime('%m/%d %H:%M') %></span>
              <div style="color: #ddd; margin-left: 10px; word-wrap: break-word;"><%= chat.body %></div>
            </div>
          <% end %>
        <% end %>
      </div>
      <form action="/alliance/chat" method="post" style="display: flex; gap: 10px; margin: 0;">
        <input type="text" name="chat_body" placeholder="同盟メンバーにメッセージを送信" maxlength="100" required style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #444; background: #222; color: #fff;">
        <button type="submit" style="padding: 10px 20px; background-color: #52c41a; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">送信</button>
      </form>
    </div>
  </div>

  <div id="menu-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); z-index: 1900; justify-content: center; align-items: center;">
    <div style="max-width: 600px; width: 90%; padding: 20px; background-color: #1a1a1a; border: 1px solid #444; border-radius: 8px; color: #fff; position: relative;">
      
      <button id="menu-close-btn" style="position: absolute; top: 12px; right: 15px; background: none; border: none; color: #aaa; font-size: 22px; cursor: pointer;">✕</button>
      <h3 style="margin-top: 0; margin-bottom: 20px; color: #bae7ff;">🛠️ 同盟管理メニュー</h3>

      <style>
        .tab-btn { background: #222; color: #aaa; }
        .tab-btn.active { background: #333; color: #fff; }
      </style>

      <div style="display: flex; gap: 5px; border-bottom: 1px solid #444; padding-bottom: 10px; margin-bottom: 20px;">
        <button class="tab-btn active" data-tab="leader" style="flex: 1; padding: 8px; border: none; cursor: pointer; font-weight: bold; font-size: 12px; border-radius: 4px;">概要</button>
        <button class="tab-btn" data-tab="main" style="flex: 1; padding: 8px; border: none; cursor: pointer; font-weight: bold; font-size: 12px; border-radius: 4px;">主要な操作</button>
        <button class="tab-btn" data-tab="manage" style="flex: 1; padding: 8px; border: none; cursor: pointer; font-weight: bold; font-size: 12px; border-radius: 4px;">管理・脱退など</button>
      </div>

      <div id="tab-leader" class="tab-content" style="display: block; min-height: 150px;">
        
        <h4 style="color: #aaa; margin-top: 0; margin-bottom: 12px;">ℹ️ 同盟紹介</h4>
        <p style="font-size: 13px; color: #666; margin-bottom: 15px;">
          ※ここには同盟の説明やイベント参加状況、宣戦布告状態などが全員向けに表示されます。
        </p>
        
        <% if @user.alliance_role == 4 %>
          <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #333;">
            <h5 style="color: #ff4d4f; margin-top: 0; margin-bottom: 10px;">👑 盟主専用コマンド</h5>
            
            <% if @alliance.users.count == 1 %>
              <p style="font-size: 13px; color: #aaa; margin-bottom: 15px;">現在メンバーはあなただけです。同盟を完全に解散することができます。</p>
              <button type="button" id="open-disband-overlay-btn" style="background-color: #ff4f4f; color: white; border: none; padding: 10px 15px; border-radius: 4px; cursor: pointer; font-weight: bold; width: 100%; transition: background 0.2s;">
                💥 同盟を解散する
              </button>
            <% else %>
              <p style="color: #ff4d4f; font-size: 13px; background: #222; padding: 10px; border-radius: 4px; border: 1px solid #5c2223; margin: 0; line-height: 1.5;">
                ⚠️ 他にメンバーが所属しているため解散できません。<br>
                解散するには、他のメンバーを全員脱退させるか、盟主を譲渡してください。
              </p>
            <% end %>
          </div>
        <% end %>
      </div>

      <div id="tab-main" class="tab-content" style="display: none; min-height: 150px;">
        <p style="color: #aaa;">⚡ 主要な操作（拡張予定地）</p>
        <p style="font-size: 13px; color: #666;">※同盟のクエスト出撃や、バフの発動などの操作を予定しています。</p>
      </div>

      <div id="tab-manage" class="tab-content" style="display: none; min-height: 150px; flex-direction: column; justify-content: space-between;">
        <div>
          <p style="color: #aaa; margin-top: 0;">👥 招待・メンバーランク管理（予定）</p>
          <p style="font-size: 13px; color: #666;">※メンバーの役職変更や招待機能の予定地です。</p>
        </div>
        
        <div style="border-top: 1px solid #333; padding-top: 15px; margin-top: 20px; text-align: right;">
          <button id="leave-alliance-btn" type="button" style="padding: 10px 20px; background-color: #ff4d4f; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; transition: background 0.2s;">
            🏃 同盟から脱退する
          </button>
        </div>
        <% if @user.alliance_role >= 3 %>
          <div style="margin-top: 30px; padding: 15px; border: 1px solid #ddd; border-radius: 8px; background-color: #fcfcfc;">
            <h4 style="margin-top: 0; color: #333; border-bottom: 2px solid #5cb85c; padding-bottom: 5px;">👑 役職別メンバー管理（副盟主以上限定）</h4>

            <details style="margin-bottom: 10px;">
              <summary style="cursor: pointer; font-weight: bold; color: #111;">👑 盟主 ▼</summary>
              <ul style="margin: 5px 0 5px 20px; list-style-type: none; padding-left: 0;">
                <% @alliance.users.select { |m| m.alliance_role == 4 }.each do |member| %>
                  <li><%= member.name %> (Lv: <%= member.level %>)</li>
                <% end %>
              </ul>
            </details>

            <details style="margin-bottom: 10px;">
              <summary style="cursor: pointer; font-weight: bold; color: #333;">⚔️ 副盟主 ▼</summary>
              <ul style="margin: 5px 0 5px 20px; list-style-type: none; padding-left: 0;">
                <% @alliance.users.select { |m| m.alliance_role == 3 }.each do |member| %>
                  <li><%= member.name %> (Lv: <%= member.level %>)</li>
                <% end %>
              </ul>
            </details>

            <details style="margin-bottom: 10px;">
              <summary style="cursor: pointer; font-weight: bold; color: #555;">👥 通常メンバー ▼</summary>
              <ul style="margin: 5px 0 5px 20px; list-style-type: none; padding-left: 0;">
                <% @alliance.users.select { |m| m.alliance_role == 2 }.each do |member| %>
                  <li><%= member.name %> (Lv: <%= member.level %>)</li>
                <% end %>
              </ul>
            </details>

            <details style="margin-bottom: 10px;" open> <summary style="cursor: pointer; font-weight: bold; color: #d9534f;">⏳ 参加申請中 ▼</summary>
              <ul style="margin: 5px 0 5px 20px; list-style-type: none; padding-left: 0;">
                <% pending_members = @alliance.users.select { |m| m.alliance_role == 1 } %>
                <% if pending_members.empty? %>
                  <li style="color: #888; font-style: italic;">現在、新しい申請はありません。</li>
                <% else %>
                  <% pending_members.each do |member| %>
                    <li style="margin-bottom: 10px; display: flex; align-items: center; gap: 10px;">
                      <span><%= member.name %> (Lv: <%= member.level %>)</span>
              
                      <form action="/alliance/approve" method="post" style="margin: 0;">
                        <input type="hidden" name="user_id" value="<%= member.id %>">
                        <button type="submit" style="background-color: #5cb85c; color: white; border: none; padding: 3px 8px; border-radius: 4px; cursor: pointer; font-size: 0.85em;">許可</button>
                      </form>

                      <form action="/alliance/reject" method="post" style="margin: 0;">
                        <input type="hidden" name="user_id" value="<%= member.id %>">
                        <button type="submit" style="background-color: #d9534f; color: white; border: none; padding: 3px 8px; border-radius: 4px; cursor: pointer; font-size: 0.85em;">拒否</button>
                      </form>
                    </li>
                  <% end %>
                <% end %>
              </ul>
            </details>

          </div>
        <% end %>
      </div>

    </div>
  </div>

  <div id="confirm-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.85); z-index: 2100; justify-content: center; align-items: center;">
    <div style="max-width: 400px; width: 85%; padding: 25px; background-color: #1a1a1a; border: 1px solid #ff4d4f; border-radius: 8px; color: #fff; text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.7);">
      <h3 style="margin-top: 0; color: #ff4d4f;">⚠️ 最終確認</h3>
      <p id="confirm-text" style="margin-bottom: 25px; font-size: 14px; line-height: 1.5; color: #ddd;">
        本当にこの同盟を脱退しますか？<br>
        <span style="font-size: 12px; color: #888;">（脱退すると同盟チャットの履歴などは見られなくなります）</span>
      </p>
      
      <div style="display: flex; gap: 12px; justify-content: center;">
        <button id="confirm-cancel-btn" style="flex: 1; padding: 10px; background-color: #333; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
          いいえ
        </button>
        
        <form id="confirm-form" action="/alliance/leave" method="post" style="flex: 1; margin: 0;">
          <button id="confirm-submit-btn" type="submit" style="width: 100%; padding: 10px; background-color: #ff4d4f; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
            はい、脱退します
          </button>
          </form>
        </div>
      </div>

    </div>
  </div>

  <script src="/js/home_chat.js"></script>
  <script src="/js/home_alliance_menu.js"></script>
</div>