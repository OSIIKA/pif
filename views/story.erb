<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css?v=3">
  <link rel="stylesheet" href="/css/story.css">
</head>
<body>
  <header>
    <div>
      <h1>紫鉄艦隊</h1>
    </div>
  </header>
  <main>
    <!-- ストーリー操作ボタン（右上固定） -->
    <!-- スキップ機能 -->
    <div class="story-ui">
      <button class="story-ui-button" id="skip-button" onclick="location.href='/story/skip'">
        スキップ
      </button>
      <button class="story-ui-button" id="log-button">
        ログ
      </button>
      <form id="auto-form" action="/story/auto" method="post" style="display:inline;">
        <input type="hidden" name="auto" id="auto-value" value="off">
        <button type="submit" class="story-ui-button" id="auto-button">
          <%= session[:auto] ? "オート中…" : "オート" %>
        </button>
      </form>
    </div>
    <!-- ログ機能 -->
    <div id="log-overlay" class="log-overlay">
      <div class="log-overlay-content">
        <h2>ログ</h2>

        <div class="log-list">
          <% session[:log].each do |entry| %>
            <div class="log-entry">
              <div class="log-name"><%= entry[:name] %></div>
              <div class="log-text"><%= entry[:text] %></div>
            </div>
          <% end %>
        </div>

        <button id="log-close" class="log-close-button">閉じる</button>
      </div>
    </div>
    <div class="message-window">
      <div class="speaker-name">
        <%= @name %>
      </div>
      <div class="message-text">
        <%= @text %>
      </div>
    </div>
  </main>
  <script>
    // Ruby の値を JS に渡す
    window.storyConfig = {
      auto: <%= session[:auto] ? 'true' : 'false' %>
    };
  </script>
  <script src="/js/story.js"></script>


</body>
</html>