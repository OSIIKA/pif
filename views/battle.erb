<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>紫鉄艦隊</title>
  <link rel="icon" href="/img/favicon.ico">
  <link rel="stylesheet" href="/css/style.css"?v=4>
  <link rel="stylesheet" href="/css/battle.css">
  <script src="/js/battle.js" defer></script>
</head>
<body class="question-view">
  <header>
    
  </header>
  <main>
    <div style="background: #111; color: #fff; padding: 30px; text-align: center; border: 1px solid #333; border-radius: 10px;">
      <h1 style="color: #ffbc00; font-size: 1.8em; margin-bottom: 10px;">⚔️ 作戦海域・戦闘フェーズ ⚔️</h1>
      <p style="color: #aaa; font-size: 1.1em; margin-bottom: 30px;">
        【 ステージ <%= @stage %> 】に突入しました。総員、対空・対潜戦闘配置！
      </p>

      <div style="background: #222; border: 1px solid #444; padding: 20px; text-align: left; max-width: 500px; margin: 0 auto; border-radius: 6px;">
        <h3 style="color: #ffbc00; margin-top: 0; border-bottom: 1px solid #444; padding-bottom: 5px;">📊 出撃艦隊データ確認</h3>
        <ul style="list-style: none; padding-left: 0; line-height: 1.8;">
          <% @fleets.each do |f| %>
            <li>
              <strong>第<%= %w(一 二 三 四 五 六)[f.fleet_number-1] %>艦隊:</strong> 
              旗艦 ID[<%= f.flagship_id || "未配備" %>] / 随伴艦 6隻
            </li>
          <% end %>
        </ul>
      </div>

      <h3 style="color: #ffbc00; margin-top: 40px;">🌌 味方陣地・ヘックスグリッド展開</h3>
      <p style="color: #aaa; font-size: 0.9em; margin-bottom: 20px;">艦隊カードをマスまでドラッグ＆ドロップして配置し、配置後もドラッグで自由に位置調整が可能です。</p>

      <div id="fleetPaletteContainer" style="display: flex; gap: 15px; justify-content: center; margin-bottom: 20px;">
        <% @fleets.each do |f| %>
          <% 
            available = !f.flagship_id.nil?
            fleet_name = "第#{%w(一 二 三 四 五 六)[f.fleet_number-1]}艦隊"
          %>
          <div class="draggable-fleet-card <%= 'available' if available %>" 
               draggable="<%= available %>"
               data-fleet-num="<%= f.fleet_number %>"
               data-fleet-name="🚢：<%= fleet_name %>"
               ondragstart="handlePaletteDragStart(event)"
               style="background: #222; border: 1px solid #444; padding: 10px; border-radius: 4px; width: 140px; text-align: center; color: #fff; cursor: <%= available ? 'grab' : 'not-allowed' %>; user-select: none; transition: 0.2s; <%= 'opacity: 0.4;' unless available %>">
            <div style="font-weight: bold;"><%= fleet_name %></div>
            <div class="status-text" style="font-size: 0.8em; color: <%= available ? '#00ffbc' : '#ff4a4a' %>;">
              <%= available ? '配置可能' : '旗艦未配備' %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="battle-map-wrapper" style="background: #0d0d1a; border: 2px solid #007bff; border-radius: 8px; padding: 20px; display: inline-block; box-shadow: 0 0 15px rgba(0,123,255,0.2);">
        <%
          hex_width = 80
          hex_height = 70
          x_spacing = hex_width * 0.75
          y_spacing = hex_height

          map_rows = 5
          map_cols = 6

          svg_width = (map_cols * x_spacing) + (hex_width * 0.25) + 20
          svg_height = (map_rows * y_spacing) + (hex_height * 0.5) + 20
        %>

        <svg width="<%= svg_width %>" height="<%= svg_height %>" style="background: rgba(0,0,0,0.5);">
          <g transform="translate(10, 10)">
            <% (0...map_cols).each do |col| %>
              <% (0...map_rows).each do |row| %>
                <%
                  # Flat-Top Offset の幾何学座標計算
                  x = col * x_spacing
                  y = row * y_spacing
                  y += (hex_height / 2) if col % 2 == 1

                  p1 = "#{x}, #{y + hex_height / 2}"
                  p2 = "#{x + hex_width * 0.25}, #{y}"
                  p3 = "#{x + hex_width * 0.75}, #{y}"
                  p4 = "#{x + hex_width}, #{y + hex_height / 2}"
                  p5 = "#{x + hex_width * 0.75}, #{y + hex_height}"
                  p6 = "#{x + hex_width * 0.25}, #{y + hex_height}"
                  
                  points = "#{p1} #{p2} #{p3} #{p4} #{p5} #{p6}"
                  
                  # JSでの配置用にマスの中心座標を計算しておく
                  center_x = x + hex_width / 2
                  center_y = y + hex_height / 2
                %>
                
                <g class="hex-cell" 
                   data-col="<%= col %>" data-row="<%= row %>"
                   data-center-x="<%= center_x %>"
                   data-center-y="<%= center_y %>"
                   ondragover="allowFleetDrop(event)" 
                   ondrop="handleFleetDrop(event)">
                  
                  <polygon points="<%= points %>" 
                           fill="rgba(0, 123, 255, 0.05)" 
                           stroke="#007bff" 
                           stroke-width="1.5"
                           style="transition: all 0.2s;" />
                  
                  <text x="<%= center_x %>" y="<%= center_y + 14 %>" 
                        class="hex-coord-text" fill="#555" font-size="10" text-anchor="middle" style="user-select: none;">
                    <%= col %>,<%= row %>
                  </text>
                </g>
              <% end %>
            <% end %>
          </g>
        </svg>
      </div>

      <div style="margin-top: 40px;">
        <form action="/battle/start" method="post" style="display: inline-block; margin-right: 10px;">
          <input type="hidden" name="stage" value="<%= @stage %>">
    
          <input type="hidden" id="input_fleet_1_pos" name="fleet_1_pos" value="">
          <input type="hidden" id="input_fleet_2_pos" name="fleet_2_pos" value="">
          <input type="hidden" id="input_fleet_3_pos" name="fleet_3_pos" value="">
          <input type="hidden" id="input_fleet_4_pos" name="fleet_4_pos" value="">
          <input type="hidden" id="input_fleet_5_pos" name="fleet_5_pos" value="">
          <input type="hidden" id="input_fleet_6_pos" name="fleet_6_pos" value="">

          <button type="submit" style="display: inline-block; background: #ffbc00; color: #000; padding: 10px 20px; border-radius: 5px; border: none; font-weight: bold; font-size: 1em; cursor: pointer; box-shadow: 0 0 10px rgba(255,188,0,0.4);">
            ⚔️ 布陣を確定して戦闘開始！
          </button>
        </form>
        <a href="/home" style="display: inline-block; background: #333; color: #fff; padding: 10px 20px; border-radius: 5px; text-decoration: none; font-weight: bold; border: 1px solid #555;">
          🏳️ 一旦撤退してホームに戻る
        </a>
      </div>
    </div>
  </main>
</body>
</html>